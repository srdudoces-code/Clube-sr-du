rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Clientes: cadastro, consulta e atualização de selos/prêmios
    match /clientes/{telefone} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Códigos de compra gerados no caixa
    match /codigos/{codigoId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // Configurações de prêmios e links (editadas pelo admin)
    match /configuracoes/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // Bloqueia qualquer outra coleção por padrão
    match /{document=**} {
      allow read, write: if false;
    }

  }
}
